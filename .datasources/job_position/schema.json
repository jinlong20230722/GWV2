{
  "name": "job_position",
  "description": "招聘职位数据模型",
  "fields": {
    "title": { "type": "string", "description": "职位名称" },
    "department": { "type": "string", "description": "部门" },
    "location": { "type": "string", "description": "工作地点" },
    "salary_range": { "type": "string", "description": "薪资范围" },
    "requirements": { "type": "array", "description": "任职要求列表" },
    "description": { "type": "text", "description": "职位描述" },
    "responsibilities": { "type": "array", "description": "岗位职责列表" },
    "benefits": { "type": "array", "description": "福利待遇列表" },
    "status": { "type": "string", "description": "状态: open招聘中, closed已关闭" },
    "sort_order": { "type": "number", "description": "排序顺序" },
    "is_active": { "type": "boolean", "description": "是否启用" },
    "created_at": { "type": "datetime", "description": "创建时间" },
    "updated_at": { "type": "datetime", "description": "更新时间" }
  }
}