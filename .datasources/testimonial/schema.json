{
  "name": "testimonial",
  "description": "客户评价数据模型",
  "fields": {
    "person_name": { "type": "string", "description": "评价人姓名" },
    "person_title": { "type": "string", "description": "评价人职位" },
    "company_name": { "type": "string", "description": "公司名称(脱敏)" },
    "company_type": { "type": "string", "description": "公司类型描述" },
    "content": { "type": "text", "description": "评价内容" },
    "rating": { "type": "number", "description": "评分: 1-5星" },
    "avatar_image": { "type": "string", "description": "头像图片URL" },
    "avatar_image_alt": { "type": "string", "description": "头像ALT文案" },
    "date": { "type": "string", "description": "评价日期" },
    "sort_order": { "type": "number", "description": "排序顺序" },
    "is_featured": { "type": "boolean", "description": "是否精选" },
    "is_active": { "type": "boolean", "description": "是否启用" },
    "created_at": { "type": "datetime", "description": "创建时间" },
    "updated_at": { "type": "datetime", "description": "更新时间" }
  }
}