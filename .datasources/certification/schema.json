{
  "name": "certification",
  "description": "资质认证数据模型",
  "fields": {
    "title": { "type": "string", "description": "认证名称" },
    "issuer": { "type": "string", "description": "颁发机构" },
    "year": { "type": "string", "description": "获得年份" },
    "description": { "type": "text", "description": "认证说明" },
    "certificate_image": { "type": "string", "description": "证书图片URL" },
    "certificate_image_alt": { "type": "string", "description": "证书图片ALT文案" },
    "certificate_number": { "type": "string", "description": "证书编号" },
    "valid_until": { "type": "date", "description": "有效期至" },
    "sort_order": { "type": "number", "description": "排序顺序" },
    "is_active": { "type": "boolean", "description": "是否启用" },
    "created_at": { "type": "datetime", "description": "创建时间" },
    "updated_at": { "type": "datetime", "description": "更新时间" }
  }
}